//@version=5
indicator("Macro News Flow Engine v2", overlay=true, max_labels_count=500, max_lines_count=500)

// GitHub Pine Seed source
seedSource = input.string("seed_asakised_macro-news-engine", "Seed Source")

// Display filters
showNews  = input.bool(true, "Show News")
showCFTC  = input.bool(true, "Show CFTC")
showCME   = input.bool(true, "Show CME")
showMacro = input.bool(true, "Show Macro")

// Table position
tablePosInput = input.string("Top Right", "Table Position", options=["Top Right", "Bottom Right", "Top Left", "Bottom Left"])

tablePos =
     tablePosInput == "Top Right"    ? position.top_right :
     tablePosInput == "Bottom Right" ? position.bottom_right :
     tablePosInput == "Top Left"     ? position.top_left :
                                       position.bottom_left

// Read seed slot
getSlot(simple string fileName) =>
    request.seed(seedSource, fileName, "EMPTY", ignore_invalid_symbol=true)

// Header row
drawHeader(table tbl) =>
    table.cell(tbl, 0, 0, "Time",     width=12, text_color=color.white, bgcolor=color.black)
    table.cell(tbl, 1, 0, "Asset",    width=10, text_color=color.white, bgcolor=color.black)
    table.cell(tbl, 2, 0, "Type",     width=16, text_color=color.white, bgcolor=color.black)
    table.cell(tbl, 3, 0, "Impact",   width=10, text_color=color.white, bgcolor=color.black)
    table.cell(tbl, 4, 0, "Source",   width=12, text_color=color.white, bgcolor=color.black)
    table.cell(tbl, 5, 0, "Headline", width=45, text_color=color.white, bgcolor=color.black)

// Impact colour
impactBg(string impact) =>
    impact == "HIGH"   ? color.new(color.red, 15) :
    impact == "MEDIUM" ? color.new(color.orange, 15) :
    impact == "LOW"    ? color.new(color.gray, 30) :
                         color.new(color.blue, 40)

// Type icon
typeIcon(string nType) =>
    nType == "NEWS"         ? "📰 " :
    nType == "CFTC"         ? "📊 " :
    nType == "CME"          ? "📈 " :
    nType == "CENTRAL_BANK" ? "🏦 " :
    nType == "COMMODITY"    ? "🛢 " :
    nType == "CRYPTO"       ? "₿ "  :
                              ""

// Process one row
processRow(series string raw, int row, table tbl) =>
    if str.length(raw) > 0 and raw != "EMPTY"
        p = str.split(raw, "|")

        if array.size(p) >= 6
            newsTime = array.get(p, 0)
            asset    = array.get(p, 1)
            nType    = array.get(p, 2)
            impact   = array.get(p, 3)
            source   = array.get(p, 4)
            headline = array.get(p, 5)

            allowed =
                 (nType == "NEWS" and showNews) or
                 (nType == "CFTC" and showCFTC) or
                 (nType == "CME" and showCME) or
                 ((nType == "CENTRAL_BANK" or nType == "COMMODITY" or nType == "CRYPTO") and showMacro)

            if allowed
                bg = impactBg(impact)
                table.cell(tbl, 0, row, newsTime,              width=12, text_color=color.white, bgcolor=color.new(color.black, 15))
                table.cell(tbl, 1, row, asset,                 width=10, text_color=color.white, bgcolor=color.new(color.black, 15))
                table.cell(tbl, 2, row, typeIcon(nType)+nType, width=16, text_color=color.white, bgcolor=color.new(color.black, 15))
                table.cell(tbl, 3, row, impact,                width=10, text_color=color.white, bgcolor=bg)
                table.cell(tbl, 4, row, source,                width=12, text_color=color.white, bgcolor=color.new(color.black, 15))
                table.cell(tbl, 5, row, headline,              width=45, text_color=color.white, bgcolor=color.new(color.black, 15))

// Fixed seed calls
slot1  = getSlot("data/MACRO_SLOT_1.txt")
slot2  = getSlot("data/MACRO_SLOT_2.txt")
slot3  = getSlot("data/MACRO_SLOT_3.txt")
slot4  = getSlot("data/MACRO_SLOT_4.txt")
slot5  = getSlot("data/MACRO_SLOT_5.txt")
slot6  = getSlot("data/MACRO_SLOT_6.txt")
slot7  = getSlot("data/MACRO_SLOT_7.txt")
slot8  = getSlot("data/MACRO_SLOT_8.txt")
slot9  = getSlot("data/MACRO_SLOT_9.txt")
slot10 = getSlot("data/MACRO_SLOT_10.txt")
slot11 = getSlot("data/MACRO_SLOT_11.txt")
slot12 = getSlot("data/MACRO_SLOT_12.txt")
slot13 = getSlot("data/MACRO_SLOT_13.txt")
slot14 = getSlot("data/MACRO_SLOT_14.txt")

// Table
var table newsTable = table.new(tablePos, 6, 15, border_width=1, frame_width=2)

if barstate.islast
    table.clear(newsTable, 0, 0, 5, 14)

    drawHeader(newsTable)

    processRow(slot1, 1, newsTable)
    processRow(slot2, 2, newsTable)
    processRow(slot3, 3, newsTable)
    processRow(slot4, 4, newsTable)
    processRow(slot5, 5, newsTable)
    processRow(slot6, 6, newsTable)
    processRow(slot7, 7, newsTable)
    processRow(slot8, 8, newsTable)
    processRow(slot9, 9, newsTable)
    processRow(slot10, 10, newsTable)
    processRow(slot11, 11, newsTable)
    processRow(slot12, 12, newsTable)
    processRow(slot13, 13, newsTable)
    processRow(slot14, 14, newsTable)
